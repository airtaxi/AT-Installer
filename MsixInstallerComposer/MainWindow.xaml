<?xml version="1.0" encoding="utf-8" ?>
<winuiex:WindowEx
    x:Class="MsixInstallerComposer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dev="using:DevWinUI"
    xmlns:local="using:MsixInstallerComposer"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:winuiex="using:WinUIEx"
    x:Uid="WindowTitle"
    Width="900"
    Height="500"
    MinWidth="800"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="AppTitleBar"
            x:Uid="AppTitleBarTitle"
            Grid.Row="0"
            BackRequested="OnAppTitleBarBackRequested"
            IsBackButtonVisible="False"
            IsPaneToggleButtonVisible="False">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="ms-appx:///Assets/Icon.png" />
            </TitleBar.IconSource>
        </TitleBar>

        <MenuBar Grid.Row="1" Background="Transparent">
            <MenuBarItem x:Uid="FileMenu" AccessKey="F">
                <MenuFlyoutItem
                    x:Uid="FileLoadMsixMenuFlyoutItem"
                    AccessKey="L"
                    Click="OnLoadMsixMenuFlyoutItemClicked">
                    <MenuFlyoutItem.Icon>
                        <FontIcon Glyph="&#xF89A;" />
                    </MenuFlyoutItem.Icon>
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Key="O" Modifiers="Control" />
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
                <MenuFlyoutSeparator />
                <MenuFlyoutItem
                    x:Uid="FileExitMenuFlyoutItem"
                    AccessKey="X"
                    Click="OnExitMenuFlyoutItemClicked">
                    <MenuFlyoutItem.Icon>
                        <FontIcon Glyph="&#xE7E8;" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
            </MenuBarItem>
            <MenuBarItem x:Uid="LanguageMenu" AccessKey="L">
                <RadioMenuFlyoutItem
                    x:Uid="EnglishLanguageMenuFlyoutItem"
                    Click="OnLanguageRadioMenuFlyoutItemClicked"
                    GroupName="ApplicationLanguage"
                    IsChecked="{x:Bind ViewModel.IsEnglishLanguageChecked, Mode=OneWay}"
                    Tag="en-US" />
                <RadioMenuFlyoutItem
                    x:Uid="KoreanLanguageMenuFlyoutItem"
                    Click="OnLanguageRadioMenuFlyoutItemClicked"
                    GroupName="ApplicationLanguage"
                    IsChecked="{x:Bind ViewModel.IsKoreanLanguageChecked, Mode=OneWay}"
                    Tag="ko-KR" />
                <RadioMenuFlyoutItem
                    x:Uid="JapaneseLanguageMenuFlyoutItem"
                    Click="OnLanguageRadioMenuFlyoutItemClicked"
                    GroupName="ApplicationLanguage"
                    IsChecked="{x:Bind ViewModel.IsJapaneseLanguageChecked, Mode=OneWay}"
                    Tag="ja-JP" />
                <RadioMenuFlyoutItem
                    x:Uid="SimplifiedChineseLanguageMenuFlyoutItem"
                    Click="OnLanguageRadioMenuFlyoutItemClicked"
                    GroupName="ApplicationLanguage"
                    IsChecked="{x:Bind ViewModel.IsSimplifiedChineseLanguageChecked, Mode=OneWay}"
                    Tag="zh-Hans" />
                <RadioMenuFlyoutItem
                    x:Uid="TraditionalChineseLanguageMenuFlyoutItem"
                    Click="OnLanguageRadioMenuFlyoutItemClicked"
                    GroupName="ApplicationLanguage"
                    IsChecked="{x:Bind ViewModel.IsTraditionalChineseLanguageChecked, Mode=OneWay}"
                    Tag="zh-Hant" />
            </MenuBarItem>
            <MenuBarItem x:Uid="HelpMenu" AccessKey="H">
                <MenuFlyoutItem
                    x:Uid="HelpAboutMenuFlyoutItem"
                    AccessKey="A"
                    Click="OnAboutMenuFlyoutItemClicked">
                    <MenuFlyoutItem.Icon>
                        <FontIcon Glyph="&#xE946;" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
            </MenuBarItem>
        </MenuBar>

        <Frame
            x:Name="AppFrame"
            Grid.Row="2"
            Navigated="OnAppFrameNavigated" />

        <Grid
            x:Name="LoadingGrid"
            Grid.Row="0"
            Grid.RowSpan="4"
            Visibility="Collapsed">

            <Rectangle Fill="{ThemeResource ThemeColor}" Opacity="0.3" />

            <dev:BlurEffectControl
                BlurAmount="10"
                IsBlurEnabled="True"
                IsTintEnabled="False" />

            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8">
                <dev:LoadingIndicator Foreground="{ThemeResource SystemAccentColor}" Mode="Arcs" />
                <TextBlock
                    x:Name="LoadingTextBlock"
                    HorizontalAlignment="Center"
                    FontWeight="Bold" />
            </StackPanel>
        </Grid>
    </Grid>
</winuiex:WindowEx>