<?xml version="1.0" encoding="utf-8" ?>
<winuiex:WindowEx
    x:Class="MsixInstallerComposer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dev="using:DevWinUI"
    xmlns:local="using:MsixInstallerComposer"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:winuiex="using:WinUIEx"
    x:Uid="WindowTitle"
    Width="1100"
    Height="600"
    MinWidth="800"
    Closed="OnMainWindowClosed"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="AppTitleBar"
            x:Uid="AppTitleBarTitle"
            Grid.Row="0"
            IsBackButtonVisible="False"
            IsPaneToggleButtonVisible="False"
            PaneToggleRequested="OnAppTitleBarPaneToggleRequested">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="ms-appx:///Assets/Icon.png" />
            </TitleBar.IconSource>
            <TitleBar.Content>
                <dev:SelectorBarSegmented
                    x:Name="PageSelectorBar"
                    SelectedItem="{x:Bind PackageExeSelectorBarItem}"
                    SelectionChanged="OnPageSelectorBarSelectionChanged">
                    <SelectorBarItem
                        x:Name="PackageExeSelectorBarItem"
                        x:Uid="PackageExeSelectorBarItem"
                        Tag="PackageExe">
                        <SelectorBarItem.Icon>
                            <FontIcon Glyph="&#xEB3B;" />
                        </SelectorBarItem.Icon>
                    </SelectorBarItem>
                    <SelectorBarItem
                        x:Name="PackageMsixSelectorBarItem"
                        x:Uid="PackageMsixSelectorBarItem"
                        Tag="PackageMsix">
                        <SelectorBarItem.Icon>
                            <FontIcon Glyph="&#xE7B8;" />
                        </SelectorBarItem.Icon>
                    </SelectorBarItem>
                    <SelectorBarItem
                        x:Name="SettingsSelectorBarItem"
                        x:Uid="SettingsSelectorBarItem"
                        Tag="Settings">
                        <SelectorBarItem.Icon>
                            <FontIcon Glyph="&#xE713;" />
                        </SelectorBarItem.Icon>
                    </SelectorBarItem>
                </dev:SelectorBarSegmented>
            </TitleBar.Content>
        </TitleBar>

        <Frame
            x:Name="AppFrame"
            Grid.Row="1"
            Navigated="OnAppFrameNavigated" />

        <Grid
            x:Name="LoadingGrid"
            Grid.Row="0"
            Grid.RowSpan="2"
            Visibility="Collapsed">

            <Rectangle Fill="{ThemeResource ThemeColor}" Opacity="0.3" />

            <dev:BlurEffectControl
                BlurAmount="10"
                IsBlurEnabled="True"
                IsTintEnabled="False" />

            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8">
                <dev:LoadingIndicator Foreground="{ThemeResource SystemAccentColor}" Mode="Arcs" />
                <TextBlock
                    x:Name="LoadingTextBlock"
                    HorizontalAlignment="Center"
                    FontWeight="Bold"
                    HorizontalTextAlignment="Center" />
            </StackPanel>
        </Grid>
    </Grid>
</winuiex:WindowEx>