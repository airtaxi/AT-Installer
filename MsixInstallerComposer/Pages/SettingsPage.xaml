<Page
    x:Class="MsixInstallerComposer.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dev="using:DevWinUI"
    xmlns:local="using:MsixInstallerComposer.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource LayerOnMicaBaseAltFillColorDefault}"
    DataContext="{x:Bind ViewModel}"
    Loaded="OnSettingsPageLoaded"
    Unloaded="OnSettingsPageUnloaded"
    mc:Ignorable="d">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid Padding="16">
            <StackPanel>
                <StackPanel Spacing="4">
                    <TextBlock x:Uid="SettingsPage_TitleTextBlock" Style="{ThemeResource TitleTextBlockStyle}" />
                    <TextBlock
                        x:Uid="SettingsPage_DescriptionTextBlock"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="Wrap" />
                </StackPanel>

                <dev:SimpleSettingsGroup x:Uid="SettingsPage_GeneralSettingsGroup">
                    <dev:SettingsCard x:Uid="SettingsPage_LanguageSettingsCard">
                        <dev:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE775;" />
                        </dev:SettingsCard.HeaderIcon>
                        <ComboBox
                            x:Name="LanguageComboBox"
                            MinWidth="220"
                            SelectedIndex="{x:Bind ViewModel.LanguageSelectedIndex, Mode=TwoWay}"
                            SelectionChanged="OnLanguageComboBoxSelectionChanged">
                            <ComboBoxItem x:Uid="SettingsPage_SystemDefaultLanguageComboBoxItem" />
                            <ComboBoxItem x:Uid="SettingsPage_KoreanLanguageComboBoxItem" />
                            <ComboBoxItem x:Uid="SettingsPage_EnglishLanguageComboBoxItem" />
                            <ComboBoxItem x:Uid="SettingsPage_JapaneseLanguageComboBoxItem" />
                            <ComboBoxItem x:Uid="SettingsPage_SimplifiedChineseLanguageComboBoxItem" />
                            <ComboBoxItem x:Uid="SettingsPage_TraditionalChineseLanguageComboBoxItem" />
                        </ComboBox>
                    </dev:SettingsCard>

                    <dev:SettingsCard x:Uid="SettingsPage_ThemeSettingsCard">
                        <dev:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE790;" />
                        </dev:SettingsCard.HeaderIcon>
                        <ComboBox
                            x:Name="ThemeComboBox"
                            MinWidth="220"
                            SelectedIndex="{x:Bind ViewModel.ThemeSelectedIndex, Mode=TwoWay}"
                            SelectionChanged="OnThemeComboBoxSelectionChanged">
                            <ComboBoxItem x:Uid="SettingsPage_SystemDefaultThemeComboBoxItem" />
                            <ComboBoxItem x:Uid="SettingsPage_LightThemeComboBoxItem" />
                            <ComboBoxItem x:Uid="SettingsPage_DarkThemeComboBoxItem" />
                        </ComboBox>
                    </dev:SettingsCard>
                </dev:SimpleSettingsGroup>

                <dev:SimpleSettingsGroup x:Uid="SettingsPage_UpdateSettingsGroup">
                    <dev:SettingsCard x:Uid="SettingsPage_UpdateCheckSettingsCard">
                        <dev:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE895;" />
                        </dev:SettingsCard.HeaderIcon>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{x:Bind ViewModel.ApplicationVersionText, Mode=OneWay}" />
                            <Button
                                x:Name="CheckForUpdatesButton"
                                Command="{x:Bind ViewModel.CheckForUpdatesCommand}"
                                IsEnabled="{x:Bind ViewModel.IsCheckForUpdatesButtonEnabled, Mode=OneWay}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontSize="14" Glyph="&#xE72C;" />
                                    <TextBlock x:Uid="SettingsPage_CheckForUpdatesButtonTextBlock" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </dev:SettingsCard>

                    <dev:SettingsCard x:Uid="SettingsPage_AutomaticUpdateCheckSettingsCard">
                        <dev:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE9F5;" />
                        </dev:SettingsCard.HeaderIcon>
                        <ToggleSwitch
                            x:Name="AutomaticUpdateCheckToggleSwitch"
                            IsOn="{x:Bind ViewModel.IsAutomaticUpdateCheckEnabled, Mode=TwoWay}"
                            Toggled="OnAutomaticUpdateCheckToggleSwitchToggled" />
                    </dev:SettingsCard>
                </dev:SimpleSettingsGroup>

                <dev:SimpleSettingsGroup x:Uid="SettingsPage_AboutSettingsGroup">
                    <dev:SettingsCard x:Uid="SettingsPage_VersionSettingsCard">
                        <dev:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE946;" />
                        </dev:SettingsCard.HeaderIcon>
                        <TextBlock
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{x:Bind ViewModel.ApplicationVersionText, Mode=OneWay}" />
                    </dev:SettingsCard>

                    <dev:SettingsCard x:Uid="SettingsPage_GitHubRepositorySettingsCard">
                        <dev:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE943;" />
                        </dev:SettingsCard.HeaderIcon>
                        <Button x:Uid="SettingsPage_GitHubRepositoryButton" Command="{x:Bind ViewModel.OpenGitHubRepositoryCommand}" />
                    </dev:SettingsCard>

                    <dev:SettingsCard x:Uid="SettingsPage_AuthorSettingsCard">
                        <dev:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE77B;" />
                        </dev:SettingsCard.HeaderIcon>
                        <TextBlock
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{x:Bind ViewModel.AuthorText, Mode=OneWay}" />
                    </dev:SettingsCard>
                </dev:SimpleSettingsGroup>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>