<Page
    x:Class="MsixInstallerComposer.Pages.PackageMsix.ManifestPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dev="using:DevWinUI"
    xmlns:local="using:MsixInstallerComposer.Pages.PackageMsix"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <ScrollViewer
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled"
            VerticalScrollBarVisibility="Auto">
            <StackPanel
                Grid.Row="0"
                Padding="0,0,0,16"
                HorizontalAlignment="Stretch"
                Spacing="16">

                <!--  Display Name Section  -->
                <dev:SettingsCard
                    x:Uid="ManifestDisplayNameCard"
                    HorizontalContentAlignment="Stretch"
                    HeaderIcon="{dev:FontIcon Glyph=&#xE932;}">
                    <TextBox
                        x:Uid="ManifestDisplayNameTextBox"
                        Width="400"
                        Text="{x:Bind ViewModel.DisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </dev:SettingsCard>

                <!--  Application Description Section  -->
                <dev:SettingsCard
                    x:Uid="ManifestApplicationDescriptionCard"
                    HorizontalContentAlignment="Stretch"
                    HeaderIcon="{dev:FontIcon Glyph=&#xE8EC;}">
                    <TextBox
                        x:Uid="ManifestApplicationDescriptionTextBox"
                        Width="400"
                        Text="{x:Bind ViewModel.ApplicationDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </dev:SettingsCard>

                <!--  Executable File Name Section  -->
                <dev:SettingsCard
                    x:Uid="ManifestExecutableFileNameCard"
                    HorizontalContentAlignment="Stretch"
                    HeaderIcon="{dev:FontIcon Glyph=&#xEB3B;}">
                    <TextBox
                        x:Uid="ManifestExecutableFileNameTextBox"
                        Width="400"
                        Text="{x:Bind ViewModel.ExecutableFileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </dev:SettingsCard>

                <!--  Logo Image Section  -->
                <dev:SettingsCard
                    HorizontalContentAlignment="Stretch"
                    Description="{x:Bind ViewModel.LogoCardDescription, Mode=OneWay}"
                    Header="{x:Bind ViewModel.LogoCardHeader, Mode=OneWay}"
                    HeaderIcon="{dev:FontIcon Glyph=&#xEB9F;}">
                    <Button
                        Width="400"
                        Command="{x:Bind ViewModel.LogoButtonCommand, Mode=OneWay}"
                        Style="{x:Bind ViewModel.LogoButtonStyle, Mode=OneWay}">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="{x:Bind ViewModel.LogoButtonGlyph, Mode=OneWay}" />
                                <TextBlock Text="{x:Bind ViewModel.LogoButtonText, Mode=OneWay}" />
                            </StackPanel>
                        </Button.Content>
                    </Button>
                </dev:SettingsCard>
            </StackPanel>
        </ScrollViewer>

        <!--  Generate and Load Config Buttons  -->
        <Grid Grid.Row="1" ColumnSpacing="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button
                x:Uid="ManifestGenerateButton"
                Grid.Column="0"
                HorizontalAlignment="Stretch"
                Command="{x:Bind ViewModel.GenerateCommand}"
                Content="Generate"
                IsEnabled="{x:Bind ViewModel.CanGenerate, Mode=OneWay}"
                Style="{StaticResource AccentButtonStyle}" />
            <Button
                x:Uid="ManifestLoadButton"
                Grid.Column="1"
                HorizontalAlignment="Stretch"
                Command="{x:Bind ViewModel.LoadConfigCommand}"
                Content="Load" />
        </Grid>
    </Grid>
</Page>