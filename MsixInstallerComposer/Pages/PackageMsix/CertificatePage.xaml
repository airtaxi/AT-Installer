<Page
    x:Class="MsixInstallerComposer.Pages.PackageMsix.CertificatePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dev="using:DevWinUI"
    xmlns:local="using:MsixInstallerComposer.Pages.PackageMsix"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <ScrollViewer
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled"
            VerticalScrollBarVisibility="Auto">
            <StackPanel
                Grid.Row="0"
                Padding="0,0,0,16"
                HorizontalAlignment="Stretch"
                Spacing="16">

                <!--  Publisher Section  -->
                <dev:SettingsCard
                    x:Uid="CertificatePublisherCard"
                    HorizontalContentAlignment="Stretch"
                    HeaderIcon="{dev:FontIcon Glyph=&#xE7C3;}">
                    <TextBox
                        x:Uid="PublisherTextBox"
                        Width="400"
                        Text="{x:Bind ViewModel.Publisher, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </dev:SettingsCard>

                <!--  Valid Days Section  -->
                <dev:SettingsCard
                    x:Uid="CertificateValidDaysCard"
                    HorizontalContentAlignment="Stretch"
                    HeaderIcon="{dev:FontIcon Glyph=&#xE8C7;}">
                    <TextBox
                        x:Uid="ValidDaysTextBox"
                        Width="400"
                        dev:TextBoxExtensions.ValidationMode="Dynamic"
                        dev:TextBoxExtensions.ValidationType="Number"
                        Text="{x:Bind ViewModel.ValidDays, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </dev:SettingsCard>

                <!--  Password Section  -->
                <dev:SettingsCard
                    x:Uid="CertificatePasswordBox"
                    HorizontalContentAlignment="Stretch"
                    HeaderIcon="{dev:FontIcon Glyph=&#xE72E;}">
                    <PasswordBox
                        x:Uid="PasswordBox"
                        Width="400"
                        Password="{x:Bind ViewModel.Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </dev:SettingsCard>
            </StackPanel>
        </ScrollViewer>

        <!--  Generate Button  -->
        <Button
            x:Uid="GenerateButton"
            Grid.Row="1"
            HorizontalAlignment="Stretch"
            Command="{x:Bind ViewModel.GenerateCommand}"
            Content="Generate"
            IsEnabled="{x:Bind ViewModel.CanGenerate, Mode=OneWay}"
            Style="{StaticResource AccentButtonStyle}" />
    </Grid>
</Page>