<Page
    x:Class="MsixInstallerComposer.Pages.PackageMsix.PackagingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dev="using:DevWinUI"
    xmlns:local="using:MsixInstallerComposer.Pages.PackageMsix"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:MsixInstallerComposer.ViewModels"
    mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
            <Style
                x:Key="RemoveButtonStyle"
                BasedOn="{StaticResource DefaultButtonStyle}"
                TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="8" />
            </Style>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <ScrollViewer
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled"
            VerticalScrollBarVisibility="Auto">
            <StackPanel
                Grid.Row="0"
                Padding="0,0,0,16"
                HorizontalAlignment="Stretch"
                Spacing="16">

                <!--  Manifest File Section  -->
                <dev:SettingsCard
                    x:Uid="PackagingManifestFileCard"
                    HorizontalContentAlignment="Stretch"
                    HeaderIcon="{dev:FontIcon Glyph=&#xF035;}">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox
                            x:Name="ManifestFilePathTextBox"
                            x:Uid="PackagingManifestFilePathTextBox"
                            Grid.Column="0"
                            Width="400"
                            IsReadOnly="True"
                            Text="{x:Bind ViewModel.ManifestFilePath, Mode=OneWay}" />

                        <Button
                            Grid.Column="1"
                            VerticalAlignment="Stretch"
                            Command="{x:Bind ViewModel.LoadManifestFileCommand}">
                            <Button.Content>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE838;" />
                                    <TextBlock x:Uid="PackagingOpenButtonText" Text="Open" />
                                </StackPanel>
                            </Button.Content>
                        </Button>
                    </Grid>
                </dev:SettingsCard>

                <!--  Certificate File Section  -->
                <dev:SettingsExpander
                    x:Uid="PackagingCertificateFileCard"
                    HorizontalContentAlignment="Stretch"
                    HeaderIcon="{dev:FontIcon Glyph=&#xEB95;}"
                    IsExpanded="{x:Bind ViewModel.HasCertificate, Mode=OneWay}">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox
                            x:Name="CertificateFilePathTextBox"
                            x:Uid="PackagingCertificateFilePathTextBox"
                            Grid.Column="0"
                            Width="400"
                            IsReadOnly="True"
                            Text="{x:Bind ViewModel.CertificateFilePath, Mode=OneWay}" />

                        <Button
                            Grid.Column="1"
                            VerticalAlignment="Stretch"
                            Command="{x:Bind ViewModel.LoadCertificateFileCommand}">
                            <Button.Content>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE838;" />
                                    <TextBlock x:Uid="PackagingOpenButtonText" Text="Open" />
                                </StackPanel>
                            </Button.Content>
                        </Button>
                    </Grid>
                    <dev:SettingsExpander.Items>
                        <dev:SettingsCard x:Uid="PackagingCertificatePasswordCard" HorizontalContentAlignment="Stretch">
                            <PasswordBox
                                x:Uid="PackagingCertificatePasswordBox"
                                Width="400"
                                IsEnabled="{x:Bind ViewModel.HasCertificate, Mode=OneWay}"
                                Password="{x:Bind ViewModel.CertificatePassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </dev:SettingsCard>
                    </dev:SettingsExpander.Items>
                </dev:SettingsExpander>

                <!--  Version Section  -->
                <dev:SettingsExpander
                    x:Uid="PackagingVersionCard"
                    HorizontalContentAlignment="Stretch"
                    HeaderIcon="{dev:FontIcon Glyph=&#xE8C7;}"
                    IsExpanded="True">
                    <dev:SettingsExpander.Items>
                        <dev:SettingsCard x:Uid="PackagingMajorVersionCard" HorizontalContentAlignment="Stretch">
                            <TextBox
                                x:Uid="PackagingMajorVersionTextBox"
                                Width="120"
                                dev:TextBoxExtensions.ValidationMode="Dynamic"
                                dev:TextBoxExtensions.ValidationType="Number"
                                Text="{x:Bind ViewModel.Major, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </dev:SettingsCard>
                        <dev:SettingsCard x:Uid="PackagingMinorVersionCard" HorizontalContentAlignment="Stretch">
                            <TextBox
                                x:Uid="PackagingMinorVersionTextBox"
                                Width="120"
                                dev:TextBoxExtensions.ValidationMode="Dynamic"
                                dev:TextBoxExtensions.ValidationType="Number"
                                Text="{x:Bind ViewModel.Minor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </dev:SettingsCard>
                        <dev:SettingsCard x:Uid="PackagingBuildVersionCard" HorizontalContentAlignment="Stretch">
                            <TextBox
                                x:Uid="PackagingBuildVersionTextBox"
                                Width="120"
                                dev:TextBoxExtensions.ValidationMode="Dynamic"
                                dev:TextBoxExtensions.ValidationType="Number"
                                Text="{x:Bind ViewModel.Build, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </dev:SettingsCard>
                        <dev:SettingsCard x:Uid="PackagingRevisionVersionCard" HorizontalContentAlignment="Stretch">
                            <TextBox
                                x:Uid="PackagingRevisionVersionTextBox"
                                Width="120"
                                dev:TextBoxExtensions.ValidationMode="Dynamic"
                                dev:TextBoxExtensions.ValidationType="Number"
                                Text="{x:Bind ViewModel.Revision, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </dev:SettingsCard>
                    </dev:SettingsExpander.Items>

                    <TextBox
                        Width="200"
                        IsReadOnly="True"
                        Text="{x:Bind ViewModel.VersionPreview, Mode=OneWay}" />
                </dev:SettingsExpander>

                <!--  Output Folder Section  -->
                <Expander
                    HorizontalContentAlignment="Stretch"
                    IsEnabled="{x:Bind ViewModel.IsOutputFolderEnabled, Mode=OneWay}"
                    IsExpanded="{x:Bind ViewModel.IsOutputFolderExpanded, Mode=TwoWay}"
                    Style="{StaticResource SettingsExpanderExpanderStyle}">
                    <Expander.Header>
                        <dev:SettingsCard
                            x:Uid="PackagingOutputFolderCard"
                            Padding="{StaticResource SettingsExpanderHeaderPadding}"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            HeaderIcon="{dev:FontIcon Glyph=&#xE8B7;}"
                            IsClickEnabled="False">
                            <Button HorizontalAlignment="Stretch" Command="{x:Bind ViewModel.AddOutputFolderCommand}">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE710;" />
                                        <TextBlock x:Uid="PackagingAddOutputFolderButtonText" Text="Add" />
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                        </dev:SettingsCard>
                    </Expander.Header>

                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.OutputFolders, Mode=OneWay}">
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:OutputFolderItemViewModel">
                                <Grid Padding="58,8,44,8" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        Text="{x:Bind DisplayText}"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="NoWrap" />

                                    <Button
                                        Grid.Column="1"
                                        Command="{x:Bind DeleteSelfCommand}"
                                        Style="{StaticResource RemoveButtonStyle}">
                                        <FontIcon Glyph="&#xE74D;" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </Expander>
            </StackPanel>
        </ScrollViewer>

        <!--  Generate Button  -->
        <Button
            x:Uid="PackagingGenerateButton"
            Grid.Row="1"
            HorizontalAlignment="Stretch"
            Command="{x:Bind ViewModel.GenerateCommand}"
            Content="Generate"
            IsEnabled="{x:Bind ViewModel.CanGenerate, Mode=OneWay}"
            Style="{StaticResource AccentButtonStyle}" />
    </Grid>
</Page>